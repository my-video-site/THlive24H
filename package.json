{
  "name": "streamboost-ai-pro",
  "version": "1.0.0",
  "description": "StreamBoost AI Pro",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "scrape": "node scripts/autoScraper.js",
    "filter": "node scripts/aiFilter.js",
    "optimize": "node scripts/affiliateOptimizer.js",
    "catalog:refresh": "node -e \"require('./server/catalog/service').refreshProviderMetadata(process.env.CATALOG_DEFAULT_PROVIDER || 'demo').then(() => console.log('catalog metadata refreshed'))\"",
